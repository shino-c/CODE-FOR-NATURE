<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox fx:id="vboxGeneral" focusTraversable="true" stylesheets="@css/loginCSS.css, @css/signUpCSS.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unknownvariables.prototype.SignUpController">
    <children>
      <VBox prefHeight="40.0" prefWidth="1326.0">
         <children>
            <HBox alignment="CENTER" prefHeight="40.0" prefWidth="1326.0">
               <children>
                  <VBox fx:id="notificationLogin" alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="400.0" style="-fx-background-color: #0b2e59;" visible="false">
                     <children>
                        <Text fx:id="notificationTextLogin" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text=" Sign up successfully. Login now">
                           <font>
                              <Font name="HarmonyOS Sans SC" size="15.0" />
                           </font>
                        </Text>
                     </children>
                     <padding>
                        <Insets left="20.0" right="20.0" />
                     </padding>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
         </children>
         <VBox.margin>
            <Insets bottom="20.0" top="-60.0" />
         </VBox.margin>
      </VBox>
        <VBox fx:id="vboxLogin">
            <children>
            <Pane prefHeight="20.0" prefWidth="360.0">
               <children>
                  <TextField editable="false" layoutX="45.0" layoutY="-3.0" opacity="0.0">
                     <cursor>
                        <Cursor fx:constant="DEFAULT" />
                     </cursor></TextField>
               </children>
               <VBox.margin>
                  <Insets bottom="-40.0" />
               </VBox.margin>
            </Pane>
                <Text fx:id="titleAppSignUp" text="Creating an account">
               <VBox.margin>
                  <Insets bottom="15.0" top="20.0" />
               </VBox.margin></Text>
            <VBox fx:id="vboxInputSignUp" prefHeight="345.0" prefWidth="300.0">
               <children>
                  <Text text="Userame" />
                  <TextField id="userInput" fx:id="usernameSignUp" onKeyTyped="#usernameValidation" promptText="Eg. JohnAnderson123" />
                  <Text fx:id="usernameErrorMessage" strokeType="OUTSIDE" strokeWidth="0.0" text=" ">
                     <VBox.margin>
                        <Insets left="5.0" top="-8.0" />
                     </VBox.margin>
                  </Text>
                  <Text text="Email" />
                  <TextField id="userInput" fx:id="emailSignUp" onKeyTyped="#emailValidation" onMouseClicked="#emailValidationClicked" promptText="Eg. yourname@email.com" />
                  <Text fx:id="emailErrorMessage" strokeType="OUTSIDE" strokeWidth="0.0" text=" ">
                     <VBox.margin>
                        <Insets left="5.0" top="-8.0" />
                     </VBox.margin>
                  </Text>
                  <Text text="Password" />
                  <PasswordField id="userInput" fx:id="passwordSignUp" onKeyTyped="#passwordValidation" onMouseClicked="#passwordValidationClicked" promptText="New password" />
                  <Text fx:id="passwordErrorMessage" strokeType="OUTSIDE" strokeWidth="0.0" text=" ">
                     <VBox.margin>
                        <Insets left="5.0" top="-8.0" />
                     </VBox.margin>
                  </Text>
                  <Text text="Confirm Password" />
                  <PasswordField id="userInput" fx:id="passwordConfirmationSignUp" onKeyTyped="#passwordConfirmationValidation" promptText="Re-enter your password" />
                  <Text fx:id="passwordConfirmationErrorMessage" strokeType="OUTSIDE" strokeWidth="0.0" text=" ">
                     <VBox.margin>
                        <Insets left="5.0" top="-8.0" />
                     </VBox.margin>
                  </Text>
               </children>
            </VBox>
                <HBox fx:id="hboxLinkLogin" prefHeight="33.0" prefWidth="360.0">
                    <VBox.margin>
                        <Insets top="-8.0" />
                    </VBox.margin>
               <children>
                  <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                            <Button fx:id="loginButton" onAction="#signUpButtonClicked" text="Sign Up" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Button fx:id="backButton" onAction="#backButtonClicked" text=" Back " />
                     </children>
                  </VBox>
               </children>
                </HBox>
            </children></VBox>
    </children>
</VBox>
