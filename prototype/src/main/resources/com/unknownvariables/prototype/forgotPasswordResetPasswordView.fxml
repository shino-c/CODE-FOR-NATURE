<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox fx:id="vboxGeneral" focusTraversable="true" stylesheets="@css/loginCSS.css, @css/signUpCSS.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unknownvariables.prototype.ForgotPasswordResetPasswordController">
    <children>
      <VBox prefHeight="40.0" prefWidth="1326.0">
         <children>
            <HBox alignment="CENTER" prefHeight="40.0" prefWidth="1326.0">
               <children>
                  <VBox fx:id="notificationFP" alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="400.0" style="-fx-background-color: #0b2e59;" visible="false">
                     <children>
                        <Text fx:id="signUpOTPTextLogin" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Verification code invalid">
                           <font>
                              <Font name="HarmonyOS Sans SC" size="15.0" />
                           </font>
                        </Text>
                     </children>
                     <padding>
                        <Insets left="20.0" right="20.0" />
                     </padding>
                  </VBox>
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </HBox>
         </children>
         <VBox.margin>
            <Insets bottom="20.0" top="-60.0" />
         </VBox.margin>
      </VBox>
        <VBox fx:id="vboxLogin">
            <children>
            <Pane prefHeight="20.0" prefWidth="360.0">
               <children>
                  <TextField editable="false" layoutX="45.0" layoutY="-3.0" opacity="0.0">
                     <cursor>
                        <Cursor fx:constant="DEFAULT" />
                     </cursor></TextField>
               </children>
               <VBox.margin>
                  <Insets bottom="-40.0" />
               </VBox.margin>
            </Pane>
                <Text fx:id="titleAppSignUp" text="Forgot Password?">
               <VBox.margin>
                  <Insets bottom="15.0" top="20.0" />
               </VBox.margin></Text>
            <VBox fx:id="vboxInputSignUp" prefHeight="345.0" prefWidth="301.0">
               <children>
                  <Text text="New password" wrappingWidth="300.0000457763672">
                     <font>
                        <Font size="16.0" />
                     </font></Text>
                  <PasswordField id="userInput" fx:id="newPassword" promptText="Abcd1234"  onKeyTyped="#newPasswordValidation"/>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" fx:id="newPasswordErrorMessage"/>
                  <Text text="Confirm new password" wrappingWidth="300.0000457763672">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Text>
                  <PasswordField id="userInput" fx:id="confirmNewPassword" promptText="Abcd1234" onKeyTyped="#confirmNewPasswordValidation"/>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" fx:id="confirmNewPasswordErrorMessage"/>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Need help? Fell free to contact us at tech_uvni@uv.com.my" wrappingWidth="300.0">
                     <VBox.margin>
                        <Insets top="5.0" />
                     </VBox.margin>
                  </Text>
               </children>
            </VBox>
                <HBox fx:id="hboxLinkLogin" prefHeight="33.0" prefWidth="360.0">
                    <VBox.margin>
                        <Insets top="-8.0" />
                    </VBox.margin>
               <children>
                  <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                            <Button fx:id="loginButton" onAction="#resetButtonClicked" text="Reset" />
                     </children>
                  </VBox>
                  <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                     <children>
                        <Button fx:id="backButton" onAction="#backButtonClicked" text=" Back " />
                     </children>
                  </VBox>
               </children>
                </HBox>
            </children></VBox>
    </children>
</VBox>
