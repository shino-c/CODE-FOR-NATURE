<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox fx:id="vboxGeneral" focusTraversable="true" stylesheets="@css/loginCSS.css, @css/signUpCSS.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.unknownvariables.prototype.LoginOTPController">
    <children>
        <VBox prefHeight="40.0" prefWidth="1326.0">
            <children>
                <HBox alignment="CENTER" prefHeight="40.0" prefWidth="1326.0">
                    <children>
                        <VBox fx:id="notificationLogin" alignment="CENTER_LEFT" prefHeight="40.0" prefWidth="400.0" style="-fx-background-color: #0b2e59;" visible="false">
                            <children>
                                <Text fx:id="loginOTPText" fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Verification code invalid">
                                    <font>
                                        <Font name="HarmonyOS Sans SC" size="15.0" />
                                    </font>
                                </Text>
                            </children>
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                        </VBox>
                    </children>
                    <VBox.margin>
                        <Insets />
                    </VBox.margin>
                </HBox>
            </children>
            <VBox.margin>
                <Insets bottom="20.0" top="-60.0" />
            </VBox.margin>
        </VBox>
        <VBox fx:id="vboxLogin">
            <children>
                <Pane prefHeight="20.0" prefWidth="360.0">
                    <children>
                        <TextField editable="false" layoutX="45.0" layoutY="-3.0" opacity="0.0">
                            <cursor>
                                <Cursor fx:constant="DEFAULT" />
                            </cursor></TextField>
                    </children>
                    <VBox.margin>
                        <Insets bottom="-40.0" />
                    </VBox.margin>
                </Pane>
                <Text fx:id="titleAppSignUp" text="Two-Factor Authentication">
                    <VBox.margin>
                        <Insets bottom="15.0" top="20.0" />
                    </VBox.margin></Text>
                <VBox fx:id="vboxInputSignUp" prefHeight="345.0" prefWidth="301.0">
                    <children>
                        <Text text="A verification code has been sent to your email address" wrappingWidth="300.0000457763672">
                            <font>
                                <Font size="16.0" />
                            </font></Text>
                        <TextField id="userInput" fx:id="otpLogin" promptText="Eg. 123456">
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin></TextField>
                        <Text text="If you didn't recieve any email from us, here are some possible problems:" wrappingWidth="300.0" />
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="(a) You are experiencing internet connection interuption" wrappingWidth="300.0" />
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="(b) Temporary service interuption affecting our server" wrappingWidth="300.0" />
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Please try again later" wrappingWidth="300.0" />
                    </children>
                </VBox>
                <HBox fx:id="hboxLinkLogin" prefHeight="33.0" prefWidth="360.0">
                    <VBox.margin>
                        <Insets top="-8.0" />
                    </VBox.margin>
                    <children>
                        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                            <children>
                                <Button fx:id="loginButton" onAction="#verifyButtonClicked" text="Verify" />
                            </children>
                        </VBox>
                        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0">
                            <children>
                                <Button fx:id="backButton" onAction="#backButtonClicked" text=" Back " />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children></VBox>
    </children>
</VBox>
